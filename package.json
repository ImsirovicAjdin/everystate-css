{
  "name": "@everystate/css",
  "version": "1.0.12",
  "description": "EveryState CSS: State-driven CSS with runtime reactive styling, design tokens, typed validation, and relational constraints",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "everystate-css-self-test": "cli.js"
  },
  "keywords": [
    "everystate",
    "state-driven-css",
    "design-tokens",
    "typed-css",
    "relational-css",
    "css-custom-properties",
    "reactive-styles",
    "theming",
    "design-system",
    "runtime-css",
    "zero-build"
  ],
  "author": {
    "name": "Ajdin Imsirovic",
    "url": "https://www.linkedin.com/in/ajdin-imsirovic"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ImsirovicAjdin/everystate-css"
  },
  "homepage": "https://github.com/ImsirovicAjdin/everystate-css#readme",
  "scripts": {
    "test": "node self-test.js",
    "self-test": "node self-test.js",
    "test:integration": "node tests/css.test.js",
    "test:i": "node tests/css.test.js"
  },
  "files": [
    "*.js",
    "*.d.ts",
    "*.md",
    "*.html",
    "cli.js",
    "tests/"
  ],
  "devDependencies": {
    "@everystate/core": "^1.0.0",
    "@everystate/test": "^1.0.0"
  },
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./designSystem": {
      "import": "./designSystem.js"
    },
    "./typedCSS": {
      "import": "./typedCSS.js"
    },
    "./relationalCSS": {
      "import": "./relationalCSS.js"
    },
    "./cssState": {
      "import": "./cssState.js"
    },
    "./styleEngine": {
      "import": "./styleEngine.js"
    },
    "./templateManager": {
      "import": "./templateManager.js"
    },
    "./stateSerializer": {
      "import": "./stateSerializer.js"
    }
  }
}
